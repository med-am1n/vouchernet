# ─────────────────────────────────────────────
#  VoucherNet — Environment Configuration
# ─────────────────────────────────────────────

# Set to "true" to use mock data (no router needed)
# Set to "false" or remove to connect to a real device
USE_MOCK=false

# MikroTik RouterOS API connection
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=vouchernet
MIKROTIK_PASSWORD=yourpassword
MIKROTIK_TIMEOUT=10000

# If the router is unreachable, automatically fall back to mock data
# instead of returning 500 errors
AUTO_FALLBACK_TO_MOCK=true

# Web server port
PORT=3000
